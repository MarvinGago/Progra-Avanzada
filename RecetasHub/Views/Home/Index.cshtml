@{
    ViewData["Title"] = "Explorar Recetas - RecetasHub";
}

<div class="container-fluid">

    <div class="card shadow-sm mb-4">
        <div class="card-body bg-light">
            <form class="row g-3 align-items-end" id="filterForm">
                <div class="col-md-3">
                    <label class="form-label">Categoría</label>
                    <select class="form-select" name="Categoria">
                        <option value="">Todas</option>
                        <option value="Desayuno">Desayuno</option>
                        <option value="Plato Principal">Plato Principal</option>
                        <option value="Postre">Postre</option>
                        <option value="Vegetariano">Vegetariano</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Fecha Desde</label>
                    <input type="date" class="form-control" name="FechaInicio">
                </div>
                <div class="col-md-3">
                    <label class="form-label">Fecha Hasta</label>
                    <input type="date" class="form-control" name="FechaFin">
                </div>
                <div class="col-md-3">
                    <button type="button" class="btn btn-danger w-100"><i class="bi bi-search"></i> Filtrar Recetas</button>
                </div>
            </form>
        </div>
    </div>

    <div class="row mb-5">
        <h4 class="border-bottom pb-2 text-danger">Top Favoritos de la Comunidad</h4>
        <div class="col-12 d-flex overflow-auto py-2" id="top-favorites-container">
            <div class="card me-3 shadow-sm" style="min-width: 20rem;">
                <img src="https://via.placeholder.com/300x150" class="card-img-top" alt="Receta Top">
                <div class="card-body">
                    <h5 class="card-title">Ramen Tonkotsu Clásico</h5>
                    <p class="card-text text-muted small">Guardada por 42 usuarios</p>
                    <button class="btn btn-sm btn-outline-danger w-100">Ver Receta</button>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <h4 class="border-bottom pb-2">Últimas Recetas</h4>
        <div class="row row-cols-1 row-cols-md-3 row-cols-lg-4 g-4" id="main-feed-container">

            <div class="col">
                <div class="card h-100 shadow-sm">
                    <img src="https://via.placeholder.com/300x200" class="card-img-top" alt="Receta Feed">
                    <div class="card-body">
                        <span class="badge bg-warning text-dark mb-2">Postre</span>
                        <h5 class="card-title">Tiramisú Auténtico</h5>
                        <p class="card-text small">Fuente: Spoonacular API</p>
                    </div>
                    <div class="card-footer bg-transparent d-flex justify-content-between align-items-center">
                        <button class="btn btn-outline-danger border-0 fs-5" title="Guardar en mis favoritos">
                            <i class="bi bi-bookmark-plus"></i> ⭐
                        </button>
                        <button class="btn btn-sm btn-secondary" title="Descargar JSON para exportar">
                            <i class="bi bi-download"></i> JSON
                        </button>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>