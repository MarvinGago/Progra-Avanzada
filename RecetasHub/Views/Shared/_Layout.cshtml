<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - RecetasHub</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/RecetasHub.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-danger mb-4 shadow-sm">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" href="/"><i class="bi bi-egg-fried"></i> RecetasHub</a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link" href="Home/MisRecetas">Mis Favoritos</a>
                        </li>

                        @if (User.IsInRole("Administrador"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-light fw-bold" href="#" id="adminDropdown"
                                   role="button" data-bs-toggle="dropdown">
                                    <i class="bi bi-shield-lock-fill"></i> Administración
                                </a>
                                <ul class="dropdown-menu dropdown-menu-dark" aria-labelledby="adminDropdown">
                                    <li><a class="dropdown-item" href="/Admin/GestionUsuarios"><i class="bi bi-people"></i> Usuarios y Permisos</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" href="/Admin/FuentesRecetas"><i class="bi bi-cloud-arrow-down"></i> Agregar APIs de Recetas</a></li>
                                    <li><a class="dropdown-item" href="/Admin/Secrets"><i class="bi bi-key"></i> Configurar Llaves (Secrets)</a></li>
                                </ul>
                            </li>
                        }
                    </ul>

                    <div class="d-flex align-items-center text-white">
                        <span class="me-3 small">Bienvenido, <strong>@User.Identity?.Name</strong></span>
                        <a href="/Account/Logout" class="btn btn-sm btn-outline-light">Salir</a>
                    </div>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - RecetasHub - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
