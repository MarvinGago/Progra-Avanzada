@{
    ViewData["Title"] = "Configurar Llaves (Secrets)";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <h2 class="mb-4"><i class="bi bi-key-fill text-warning"></i> Bóveda de API Keys</h2>

            <div class="card shadow-sm border-warning">
                <div class="card-body p-4">
                    <p class="text-muted mb-4">
                        Almacena aquí los tokens de acceso requeridos por las APIs externas.
                    </p>
                    <form asp-action="SaveSecret" method="post">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Identificador de la Llave (KeyName)</label>
                            <input type="text" class="form-control" name="KeyName" placeholder="Ej. Spoon_Key_123" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Valor del Token (KeyValue)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="bi bi-lock"></i></span>
                                <input type="password" class="form-control" name="KeyValue" placeholder="Pegar token aquí" required />
                            </div>
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-bold">Descripción del uso</label>
                            <input type="text" class="form-control" name="Description" placeholder="Ej. Token de la cuenta de pruebas" />
                        </div>
                        <button type="submit" class="btn btn-dark w-100 fw-bold">Guardar Llave</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>