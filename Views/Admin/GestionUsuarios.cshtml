@{
    ViewData["Title"] = "Gestión de Usuarios";
}

<div class="container mt-4">
    <h2 class="mb-4"><i class="bi bi-people-fill text-primary"></i> Usuarios y Permisos</h2>

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>ID</th>
                            <th>Usuario</th>
                            <th>Rol Actual</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>1</td>
                            <td class="fw-bold">diego_admin</td>
                            <td><span class="badge bg-danger">Administrador</span></td>
                            <td>
                                <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#editRoleModal">Cambiar Rol</button>
                            </td>
                        </tr>
                        <tr>
                            <td>2</td>
                            <td>chef_invitado</td>
                            <td><span class="badge bg-secondary">Estándar</span></td>
                            <td>
                                <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#editRoleModal">Cambiar Rol</button>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="editRoleModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Modificar Permisos</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form asp-action="UpdateUserRole" method="post">
                    <input type="hidden" name="UserId" value="1" /> <div class="mb-3">
                    <label class="form-label">Seleccionar Nuevo Rol</label>
                    <select class="form-select" name="RoleId">
                        <option value="1">Administrador</option>
                        <option value="2">Estándar</option>
                    </select>
                </div>
                <button type="submit" class="btn btn-primary w-100">Guardar Cambios</button>
            </form>
        </div>
    </div>
</div>
</div>